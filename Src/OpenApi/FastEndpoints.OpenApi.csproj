<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFrameworks>net10.0;</TargetFrameworks> <!-- disable multi targeting from Directory.Build.Props -->
        <NoWarn>1701;1702;CS1591;CS1573</NoWarn>
        <Description>OpenAPI support for FastEndpoints using Microsoft.AspNetCore.OpenApi</Description>
    </PropertyGroup>

    <ItemGroup>
        <ProjectReference Include="..\Library\FastEndpoints.csproj"/>
        <PackageReference Include="Microsoft.AspNetCore.OpenApi"/>
        <PackageReference Include="FluentValidation"/>
        <PackageReference Include="Microsoft.SourceLink.GitHub" PrivateAssets="All"/>
    </ItemGroup>

    <ItemGroup>
        <FrameworkReference Include="Microsoft.AspNetCore.App"/>
    </ItemGroup>

    <ItemGroup>
        <None Include="..\icon.png" Pack="true" PackagePath="\" Link="Content\Icon" Visible="false"/>
        <None Include="FastEndpoints.OpenApi.targets" Pack="true" PackagePath="build\FastEndpoints.OpenApi.targets" Visible="true"/>
    </ItemGroup>

    <Import Project="FastEndpoints.OpenApi.targets"/>

</Project>
