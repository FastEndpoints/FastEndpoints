<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

    <PropertyGroup>
        <OpenApiExportPath Condition="'$(OpenApiExportPath)' == ''">wwwroot/openapi</OpenApiExportPath>
    </PropertyGroup>

    <!-- Generate module initializer to set OpenApiExportPath at runtime -->
    <Target Name="GenerateOpenApiExportPathInitializer"
            BeforeTargets="CoreCompile"
            Condition="'$(MSBuildProjectName)' != 'FastEndpoints.OpenApi'">
        <PropertyGroup>
            <_OpenApiInitFile>$(IntermediateOutputPath)OpenApiExportPathInitializer.g.cs</_OpenApiInitFile>
            <_OpenApiInitFileContent>
using System.Runtime.CompilerServices%3b
namespace FastEndpoints.OpenApi%3b
internal static class OpenApiExportPathInitializer
{
    [ModuleInitializer]
    internal static void Initialize() => DocumentOptions.OpenApiExportPath = "$(OpenApiExportPath)"%3b
}
            </_OpenApiInitFileContent>
        </PropertyGroup>
        <WriteLinesToFile File="$(_OpenApiInitFile)" Lines="$(_OpenApiInitFileContent)" Overwrite="true" WriteOnlyWhenDifferent="true"/>
        <ItemGroup>
            <Compile Include="$(_OpenApiInitFile)"/>
        </ItemGroup>
    </Target>

    <!--
      Single JIT build + one process for all enabled AOT export formats.
      Enable via ExportOpenApiDocs and/or ExportHttpFiles (shared OpenApiExportPath).
      When both are true, pass both CLI flags; one Export*AndExitAsync call exports every requested format.
      Alias target names kept for discoverability.
    -->
    <Target Name="ExportOpenApiArtifactsBeforeAotPublish"
            BeforeTargets="PrepareForILLink"
            Condition="'$(PublishAot)' == 'true' AND '$(_OpenApiArtifactsExporting)' != 'true' AND ('$(ExportOpenApiDocs)' == 'true' OR '$(ExportHttpFiles)' == 'true')">

        <PropertyGroup>
            <_FeAotExportDir>$(IntermediateOutputPath)openapi_export\</_FeAotExportDir>
            <_FeAotCliArgs></_FeAotCliArgs>
            <_FeAotCliArgs Condition="'$(ExportOpenApiDocs)' == 'true'">$(_FeAotCliArgs) --export-openapi-docs true</_FeAotCliArgs>
            <_FeAotCliArgs Condition="'$(ExportHttpFiles)' == 'true'">$(_FeAotCliArgs) --export-http-files true</_FeAotCliArgs>
            <_FeAotDisplayName Condition="'$(ExportOpenApiDocs)' == 'true' AND '$(ExportHttpFiles)' == 'true'">OpenAPI documents and '.http' files</_FeAotDisplayName>
            <_FeAotDisplayName Condition="'$(ExportOpenApiDocs)' == 'true' AND '$(ExportHttpFiles)' != 'true'">OpenAPI documents</_FeAotDisplayName>
            <_FeAotDisplayName Condition="'$(ExportOpenApiDocs)' != 'true' AND '$(ExportHttpFiles)' == 'true'">'.http' files</_FeAotDisplayName>
        </PropertyGroup>

        <Message Text="Exporting $(_FeAotDisplayName) before Native AOT compilation..." Importance="high"/>
        <Message Text="OpenAPI export path: $(OpenApiExportPath)" Importance="high"/>

        <!-- Build JIT version (non-AOT) once for all requested formats -->
        <MSBuild Projects="$(MSBuildProjectFullPath)"
                 Targets="Build"
                 Properties="PublishAot=false;_OpenApiArtifactsExporting=true;OpenApiExportPath=$(OpenApiExportPath);OutputPath=$(_FeAotExportDir)"/>

        <!-- Run the JIT build once; both CLI flags may be present -->
        <Exec Command="dotnet exec $(_FeAotExportDir)$(AssemblyName).dll$(_FeAotCliArgs)"
              WorkingDirectory="$(MSBuildProjectDirectory)"
              IgnoreExitCode="true">
            <Output TaskParameter="ExitCode" PropertyName="_FeAotExportExitCode"/>
        </Exec>

        <Warning Text="$(_FeAotDisplayName) export failed with exit code $(_FeAotExportExitCode)"
                 Condition="'$(_FeAotExportExitCode)' != '0'"/>
        <Message Text="$(_FeAotDisplayName) exported successfully" Importance="high"
                 Condition="'$(_FeAotExportExitCode)' == '0'"/>

        <!-- Copy exported files to publish directory -->
        <ItemGroup Condition="'$(_FeAotExportExitCode)' == '0' AND '$(PublishDir)' != ''">
            <!-- JSON export (or both): copy everything under the export path -->
            <_FeAotExportFiles Include="$(MSBuildProjectDirectory)\$(OpenApiExportPath)\**\*"
                               Condition="'$(ExportOpenApiDocs)' == 'true'"/>
            <!-- HTTP-only: only .http files -->
            <_FeAotExportFiles Include="$(MSBuildProjectDirectory)\$(OpenApiExportPath)\**\*.http"
                               Condition="'$(ExportOpenApiDocs)' != 'true' AND '$(ExportHttpFiles)' == 'true'"/>
        </ItemGroup>
        <Copy SourceFiles="@(_FeAotExportFiles)"
              DestinationFolder="$(PublishDir)$(OpenApiExportPath)\%(RecursiveDir)"
              Condition="'@(_FeAotExportFiles)' != ''"
              SkipUnchangedFiles="true"/>
    </Target>

    <!-- Alias targets (discoverability / explicit DependsOn) -->
    <Target Name="ExportOpenApiDocsBeforeAotPublish" DependsOnTargets="ExportOpenApiArtifactsBeforeAotPublish"/>
    <Target Name="ExportHttpFilesBeforeAotPublish" DependsOnTargets="ExportOpenApiArtifactsBeforeAotPublish"/>

</Project>
