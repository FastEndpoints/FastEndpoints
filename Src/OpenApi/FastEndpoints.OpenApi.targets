<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

    <PropertyGroup>
        <OpenApiExportPath Condition="'$(OpenApiExportPath)' == ''">wwwroot/openapi</OpenApiExportPath>
    </PropertyGroup>

    <!-- Generate module initializer to set OpenApiExportPath at runtime -->
    <Target Name="GenerateOpenApiExportPathInitializer"
            BeforeTargets="CoreCompile"
            Condition="'$(MSBuildProjectName)' != 'FastEndpoints.OpenApi'">
        <PropertyGroup>
            <_OpenApiInitFile>$(IntermediateOutputPath)OpenApiExportPathInitializer.g.cs</_OpenApiInitFile>
            <_OpenApiInitFileContent>
using System.Runtime.CompilerServices%3b
namespace FastEndpoints.OpenApi%3b
internal static class OpenApiExportPathInitializer
{
    [ModuleInitializer]
    internal static void Initialize() => DocumentOptions.OpenApiExportPath = "$(OpenApiExportPath)"%3b
}
            </_OpenApiInitFileContent>
        </PropertyGroup>
        <WriteLinesToFile File="$(_OpenApiInitFile)" Lines="$(_OpenApiInitFileContent)" Overwrite="true" WriteOnlyWhenDifferent="true"/>
        <ItemGroup>
            <Compile Include="$(_OpenApiInitFile)"/>
        </ItemGroup>
    </Target>

    <!--
      AOT pre-publish export descriptors.
      Enable via ExportOpenApiDocs / ExportHttpFiles (and shared OpenApiExportPath).
      Each format still gets its own JIT build + exec; alias target names kept for discoverability.
    -->
    <ItemGroup Condition="'$(PublishAot)' == 'true' AND '$(_OpenApiArtifactsExporting)' != 'true'">
        <_FeAotExport Include="OpenApiDocs" Condition="'$(ExportOpenApiDocs)' == 'true'">
            <IntermediateDir>$(IntermediateOutputPath)openapi_export\</IntermediateDir>
            <CliArg>--export-openapi-docs true</CliArg>
            <IncludeGlob>**\*</IncludeGlob>
            <DisplayName>OpenAPI documents</DisplayName>
            <QuotedName>OpenAPI documents</QuotedName>
        </_FeAotExport>
        <_FeAotExport Include="HttpFiles" Condition="'$(ExportHttpFiles)' == 'true'">
            <IntermediateDir>$(IntermediateOutputPath)http_export\</IntermediateDir>
            <CliArg>--export-http-files true</CliArg>
            <IncludeGlob>**\*.http</IncludeGlob>
            <DisplayName>'.http' files</DisplayName>
            <QuotedName>'.http' files</QuotedName>
        </_FeAotExport>
    </ItemGroup>

    <!-- Export OpenAPI artifacts via JIT build before AOT publish (batched per format) -->
    <Target Name="ExportOpenApiArtifactsBeforeAotPublish"
            BeforeTargets="PrepareForILLink"
            Condition="'@(_FeAotExport)' != ''"
            Outputs="%(_FeAotExport.Identity)">

        <Message Text="Exporting %(_FeAotExport.DisplayName) before Native AOT compilation..." Importance="high"/>
        <Message Text="%(_FeAotExport.QuotedName) export path: $(OpenApiExportPath)" Importance="high"/>

        <!-- Build JIT version (non-AOT) with OpenApiExportPath explicitly passed -->
        <MSBuild Projects="$(MSBuildProjectFullPath)"
                 Targets="Build"
                 Properties="PublishAot=false;_OpenApiArtifactsExporting=true;OpenApiExportPath=$(OpenApiExportPath);OutputPath=%(_FeAotExport.IntermediateDir)"/>

        <!-- Run the JIT build to export artifacts -->
        <Exec Command="dotnet exec %(_FeAotExport.IntermediateDir)$(AssemblyName).dll %(_FeAotExport.CliArg)"
              WorkingDirectory="$(MSBuildProjectDirectory)"
              IgnoreExitCode="true">
            <Output TaskParameter="ExitCode" PropertyName="_FeAotExportExitCode"/>
        </Exec>

        <Warning Text="%(_FeAotExport.QuotedName) export failed with exit code $(_FeAotExportExitCode)"
                 Condition="'$(_FeAotExportExitCode)' != '0'"/>
        <Message Text="%(_FeAotExport.QuotedName) exported successfully" Importance="high"
                 Condition="'$(_FeAotExportExitCode)' == '0'"/>

        <!-- Copy exported files to publish directory -->
        <ItemGroup Condition="'$(_FeAotExportExitCode)' == '0' AND '$(PublishDir)' != ''">
            <_FeAotExportFiles Include="$(MSBuildProjectDirectory)\$(OpenApiExportPath)\%(_FeAotExport.IncludeGlob)"/>
        </ItemGroup>
        <Copy SourceFiles="@(_FeAotExportFiles)"
              DestinationFolder="$(PublishDir)$(OpenApiExportPath)\%(RecursiveDir)"
              Condition="'@(_FeAotExportFiles)' != ''"
              SkipUnchangedFiles="true"/>
        <ItemGroup>
            <_FeAotExportFiles Remove="@(_FeAotExportFiles)"/>
        </ItemGroup>
    </Target>

    <!-- Alias targets (discoverability / explicit DependsOn) -->
    <Target Name="ExportOpenApiDocsBeforeAotPublish" DependsOnTargets="ExportOpenApiArtifactsBeforeAotPublish"/>
    <Target Name="ExportHttpFilesBeforeAotPublish" DependsOnTargets="ExportOpenApiArtifactsBeforeAotPublish"/>

</Project>
